    {
      "address": "0x0000000000000000000000000000000000000000",
      "role": "treasury",
      "chain": "base",
      "notes": "Main protocol treasury"
    },
    {
      "address": "0x0000000000000000000000000000000000000000",
      "role": "deployer",
      "chain": "base",
      "notes": "Contract deployer"
    }
  ]
}
